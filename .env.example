# Copy this file to .env and fill in your Supabase credentials.
# .env is gitignored — never commit real keys.
#
# These same variable names must be set in the Vercel dashboard:
#   Settings → Environment Variables
#
# NG_APP_SUPABASE_URL  — Project URL, e.g. https://xxxx.supabase.co
# NG_APP_SUPABASE_KEY  — anon/public key (safe to expose in the browser)

NG_APP_SUPABASE_URL=https://your-project-id.supabase.co
NG_APP_SUPABASE_KEY=your-anon-key-here
